{
  "name": "Hermes Agent",
  "version": "1.0.0",
  "description": "Universal AI Agent Orchestrator with OpenRouter and Local Model Support",
  "mode": "universal",
  "orchestration": {
    "enabled": true,
    "agents": [
      {
        "id": "openclaw-bridge",
        "name": "OpenClaw Bridge",
        "type": "bridge",
        "endpoint": "http://localhost:18789",
        "enabled": true,
        "priority": 1
      },
      {
        "id": "pi-agent",
        "name": "Pi Coding Agent",
        "type": "pi",
        "endpoint": "http://localhost:31415",
        "enabled": true,
        "priority": 2
      },
      {
        "id": ".claude",
        "name": "Claude Code Agent",
        "type": "claude",
        "enabled": true,
        "priority": 3
      },
      {
        "id": "local-ollama",
        "name": "Local Ollama Models",
        "type": "ollama",
        "endpoint": "http://localhost:11434",
        "enabled": true,
        "priority": 0
      }
    ],
    "routing": {
      "strategy": "cost-optimized",
      "fallback": true,
      "loadBalancing": "round-robin"
    }
  },
  "models": {
    "openrouter": {
      "enabled": true,
      "baseUrl": "https://openrouter.ai/api/v1",
      "apiKey": "${OPENROUTER_API_KEY}",
      "freeModels": [
        {
          "id": "qwen/qwen3-next-80b-a3b-instruct:free",
          "name": "Qwen 3 Next 80B A3B Instruct",
          "context": 32000,
          "costPer1k": 0,
          "speed": "fast",
          "useCase": "code",
          "enabled": true
        },
        {
          "id": "google/gemini-2.5-flash-exp:free",
          "name": "Gemini 2.5 Flash Experimental",
          "context": 1000000,
          "costPer1k": 0,
          "speed": "fast",
          "useCase": "general",
          "enabled": true
        },
        {
          "id": "google/gemini-2.0-flash-exp:free",
          "name": "Gemini 2.0 Flash Experimental",
          "context": 1048576,
          "costPer1k": 0,
          "speed": "fast",
          "useCase": "general",
          "enabled": true
        },
        {
          "id": "deepseek/deepseek-r1:free",
          "name": "DeepSeek R1",
          "context": 128000,
          "costPer1k": 0,
          "speed": "medium",
          "useCase": "reasoning",
          "enabled": true
        },
        {
          "id": "deepseek/deepseek-r1-distill-llama-70b:free",
          "name": "DeepSeek R1 Distill Llama 70B",
          "context": 128000,
          "costPer1k": 0,
          "speed": "medium",
          "useCase": "reasoning",
          "enabled": true
        },
        {
          "id": "deepseek/deepseek-chat:free",
          "name": "DeepSeek V3",
          "context": 64000,
          "costPer1k": 0,
          "speed": "fast",
          "useCase": "general",
          "enabled": true
        },
        {
          "id": "shuttleai/shuttle-3:free",
          "name": "Shuttle 3",
          "context": 32768,
          "costPer1k": 0,
          "speed": "fast",
          "useCase": "general",
          "enabled": true
        },
        {
          "id": "shuttleai/shuttle-3-mini:free",
          "name": "Shuttle 3 Mini",
          "context": 32768,
          "costPer1k": 0,
          "speed": "fast",
          "useCase": "general",
          "enabled": true
        }
      ],
      "routing": {
        "default": "qwen/qwen3-next-80b-a3b-instruct:free",
        "byTask": {
          "code": "qwen/qwen3-next-80b-a3b-instruct:free",
          "reasoning": "deepseek/deepseek-r1:free",
          "fast": "google/gemini-2.0-flash-exp:free",
          "creative": "google/gemini-2.5-flash-exp:free"
        }
      },
      "rateLimits": {
        "requestsPerMinute": 20,
        "requestsPerDay": 200
      }
    },
    "local": {
      "enabled": true,
      "ollama": {
        "baseUrl": "http://localhost:11434",
        "models": [
          {
            "id": "llama3.2",
            "name": "Llama 3.2",
            "size": "3B",
            "useCase": "fast",
            "enabled": true
          },
          {
            "id": "phi3:latest",
            "name": "Phi-3",
            "size": "14B",
            "useCase": "balanced",
            "enabled": true
          },
          {
            "id": "qwen2.5-coder",
            "name": "Qwen 2.5 Coder",
            "size": "7B",
            "useCase": "code",
            "enabled": true
          },
          {
            "id": "gemma2:9b",
            "name": "Gemma 2 9B",
            "size": "9B",
            "useCase": "general",
            "enabled": true
          },
          {
            "id": "mistral",
            "name": "Mistral",
            "size": "7B",
            "useCase": "general",
            "enabled": true
          },
          {
            "id": "nomic-embed-text",
            "name": "Nomic Embed Text",
            "size": "1.5B",
            "useCase": "embeddings",
            "enabled": true
          }
        ],
        "autoDownload": true
      }
    }
  },
  "features": {
    "mcp": {
      "enabled": true,
      "servers": [
        "filesystem",
        "web-search",
        "github",
        "brave-search",
        "openrouter-stats"
      ]
    },
    "code": {
      "execution": {
        "enabled": true,
        "sandbox": true
      },
      "linter": true,
      "formatter": true
    },
    "search": {
      "web": true,
      "local": true,
      "hybrid": true
    },
    "memory": {
      "enabled": true,
      "persistence": true,
      "embeddingModel": "nomic-embed-text",
      "ragEnabled": true
    }
  },
  "workflow": {
    "autoSave": true,
    "checkpoints": true,
    "parallelExecution": true,
    "subAgents": {
      "enabled": true,
      "maxConcurrent": 4
    }
  },
  "logging": {
    "level": "INFO",
    "file": "~/.hermes/logs/hermes.log",
    "rotation": "daily",
    "maxFiles": 7
  }
}
